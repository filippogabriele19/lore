{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ES2022",
    "outDir": "./out",
    "lib": [
      "ES2022"
    ],
    "sourceMap": true,
    "strict": true,
    "rootDir": "./src",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "moduleResolution": "NodeNext"
  },
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
