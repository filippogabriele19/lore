# LORE Environment Configuration Example
# Copy this file to .env and fill in your API keys.

# Anthropic API Key (Required for Claude models used in reconciler and guardian)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API Key (Optional fallback or for specific model evaluations)
OPENAI_API_KEY=your-openai-api-key-here

# LORE Server configuration
LORE_PORT=8787
LORE_HOST=127.0.0.1
